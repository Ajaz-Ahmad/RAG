# Required — for answer generation only
OPENAI_API_KEY=sk-...

# Embeddings run locally by default (sentence-transformers, free, no key needed).
# Set USE_LOCAL_EMBEDDINGS=false to use the OpenAI embedding API instead.
# USE_LOCAL_EMBEDDINGS=false

# Optional overrides
OPENAI_MODEL=gpt-4o-mini
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# To use a local vLLM server for embeddings:
# USE_LOCAL_EMBEDDINGS=false
# EMBEDDING_BASE_URL=http://localhost:8000/v1
# EMBEDDING_API_KEY=EMPTY
