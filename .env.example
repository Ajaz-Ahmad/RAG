# Required — used for both embeddings and generation
OPENAI_API_KEY=sk-...

# Optional overrides
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# To use a local vLLM server for embeddings instead of OpenAI:
# EMBEDDING_BASE_URL=http://localhost:8000/v1
# EMBEDDING_API_KEY=EMPTY
# EMBEDDING_MODEL=     # auto-detect from vLLM
