# ── Generation ────────────────────────────────────────────────────────────────
# Groq is free (no credit card): https://console.groq.com → API Keys
OPENAI_API_KEY=gsk_...           # Groq key starts with gsk_

# Groq defaults (already set in config.py — only override if needed)
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile

# To use OpenAI instead:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ── Embeddings (local by default, no key needed) ───────────────────────────────
# USE_LOCAL_EMBEDDINGS=true      # default — sentence-transformers, free
# LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── vLLM embeddings (optional override) ───────────────────────────────────────
# USE_LOCAL_EMBEDDINGS=false
# EMBEDDING_BASE_URL=http://localhost:8000/v1
# EMBEDDING_API_KEY=EMPTY
